{
  "name": "smartstore-api",
  "version": "1.0.0",
  "description": "SmartStore Backend API - Express + PostgreSQL",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "update:component-schemas": "node src/db/scripts/update_component_schemas.js",
    "test": "NODE_ENV=test jest --coverage --runInBand",
    "test:auth": "NODE_ENV=test jest src/tests/auth.test.js --runInBand",
    "test:rbac": "NODE_ENV=test jest src/tests/rbac.test.js --runInBand",
    "test:orders": "NODE_ENV=test jest src/tests/orders.test.js --runInBand",
    "test:templates": "NODE_ENV=test jest src/tests/templates.test.js --runInBand",
    "test:assets": "NODE_ENV=test jest src/tests/assets.test.js --runInBand",
    "test:theme": "NODE_ENV=test jest src/tests/customization-theme.test.js --runInBand",
    "test:bio": "NODE_ENV=test jest src/tests/bio.test.js --runInBand",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:verbose": "NODE_ENV=test jest --verbose --runInBand",
    "test:cleanup": "node src/tests/test-db-cleanup.js",
    "rbac": "node scripts/rbac.js",
    "rbac:setup": "node scripts/rbac.js setup-common",
    "rbac:create-role": "node scripts/create-role.js",
    "rbac:create-permission": "node scripts/create-permission.js",
    "rbac:add-permission-to-role": "node scripts/add-permission-to-role.js",
    "rbac:add-role-to-user": "node scripts/add-role-to-user.js",
    "rbac:list-user-roles": "node scripts/list-user-roles.js",
    "rbac:list-role-permissions": "node scripts/list-role-permissions.js"
  },
  "keywords": [
    "express",
    "postgresql",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.948.0",
    "@aws-sdk/s3-request-presigner": "^3.948.0",
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nanoid": "^3.3.11",
    "nodemailer": "^7.0.11",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-twitter": "^1.0.4",
    "pg": "^8.11.3",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "form-data": "^4.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}
