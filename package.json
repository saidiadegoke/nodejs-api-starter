{
  "name": "node-api-template",
  "version": "1.0.0",
  "description": "Node.js + Express + PostgreSQL API starter template with JWT auth, RBAC, file uploads, notifications, WebSocket, and Swagger docs.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "test": "NODE_ENV=test jest --coverage --runInBand",
    "test:auth": "NODE_ENV=test jest src/tests/auth.api.test.js --runInBand",
    "test:rbac": "NODE_ENV=test jest src/tests/rbac.test.js --runInBand",
    "test:assets": "NODE_ENV=test jest src/tests/assets.test.js --runInBand",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:verbose": "NODE_ENV=test jest --verbose --runInBand",
    "test:cleanup": "node src/tests/test-db-cleanup.js",
    "rbac": "node scripts/rbac.js",
    "rbac:setup": "node scripts/rbac.js setup-common",
    "rbac:create-role": "node scripts/create-role.js",
    "rbac:create-permission": "node scripts/create-permission.js",
    "rbac:add-permission-to-role": "node scripts/add-permission-to-role.js",
    "rbac:add-role-to-user": "node scripts/add-role-to-user.js",
    "rbac:list-user-roles": "node scripts/list-user-roles.js",
    "rbac:list-role-permissions": "node scripts/list-role-permissions.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saidiadegoke/nodejs-api-starter.git"
  },
  "bugs": {
    "url": "https://github.com/saidiadegoke/nodejs-api-starter/issues"
  },
  "homepage": "https://github.com/saidiadegoke/nodejs-api-starter#readme",
  "keywords": [
    "express",
    "postgresql",
    "api",
    "starter",
    "template",
    "jwt",
    "rbac",
    "authentication",
    "swagger",
    "openapi",
    "websocket",
    "s3"
  ],
  "author": "Saidi Adegoke <rasheedsaidi@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.948.0",
    "@aws-sdk/s3-request-presigner": "^3.948.0",
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^18.0.2",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nanoid": "^3.3.11",
    "nodemailer": "^8.0.6",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-twitter": "^0.1.5",
    "pg": "^8.11.3",
    "socket.io": "^4.7.5",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "form-data": "^4.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}
