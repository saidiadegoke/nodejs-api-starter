# SmartStore Production Nginx Configuration
# This is a template configuration file for production deployment
# Copy this to /etc/nginx/nginx.conf and customize as needed

user nginx;
worker_processes auto;
error_log /var/log/nginx/error.log warn;
pid /var/run/nginx.pid;

events {
    worker_connections 1024;
    use epoll;
}

http {
    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    log_format main '$remote_addr - $remote_user [$time_local] "$request" '
                    '$status $body_bytes_sent "$http_referer" '
                    '"$http_user_agent" "$http_x_forwarded_for"';

    access_log /var/log/nginx/access.log main;

    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;
    keepalive_timeout 65;
    types_hash_max_size 2048;
    client_max_body_size 20M;

    # Gzip compression
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types text/plain text/css text/xml text/javascript 
               application/json application/javascript application/xml+rss 
               application/rss+xml font/truetype font/opentype 
               application/vnd.ms-fontobject image/svg+xml;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Rate limiting
    limit_req_zone $binary_remote_addr zone=api_limit:10m rate=10r/s;
    limit_req_zone $binary_remote_addr zone=general_limit:10m rate=30r/s;

    # Upstream backend servers
    upstream smartstore_app {
        server localhost:3002;
        keepalive 32;
    }

    upstream smartstore_api {
        server localhost:4050;
        keepalive 32;
    }

    upstream smartstore_web {
        server localhost:3001;
        keepalive 32;
    }

    # Redirect HTTP to HTTPS for base domain
    server {
        listen 80;
        server_name smartstore.org www.smartstore.org;
        return 301 https://$server_name$request_uri;
    }

    # Base domain HTTPS (dashboard/admin)
    server {
        listen 443 ssl http2;
        server_name smartstore.org www.smartstore.org;

        # SSL Certificate (replace with your certificate paths)
        ssl_certificate /etc/ssl/smartstore/base-domain.crt;
        ssl_certificate_key /etc/ssl/smartstore/base-domain.key;

        # SSL Configuration
        ssl_protocols TLSv1.2 TLSv1.3;
        ssl_ciphers HIGH:!aNULL:!MD5;
        ssl_prefer_server_ciphers on;
        ssl_session_cache shared:SSL:10m;
        ssl_session_timeout 10m;
        ssl_session_tickets off;

        # Security Headers
        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

        # Dashboard/Admin routes
        location / {
            proxy_pass http://smartstore_web;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection 'upgrade';
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_cache_bypass $http_upgrade;
        }
    }

    # Wildcard subdomain for sites (*.smartstore.org)
    server {
        listen 80;
        server_name *.smartstore.org;
        return 301 https://$server_name$request_uri;
    }

    server {
        listen 443 ssl http2;
        server_name *.smartstore.org;

        # Wildcard SSL Certificate
        ssl_certificate /etc/ssl/smartstore/wildcard.crt;
        ssl_certificate_key /etc/ssl/smartstore/wildcard.key;

        # SSL Configuration
        ssl_protocols TLSv1.2 TLSv1.3;
        ssl_ciphers HIGH:!aNULL:!MD5;
        ssl_prefer_server_ciphers on;
        ssl_session_cache shared:SSL:10m;
        ssl_session_timeout 10m;
        ssl_session_tickets off;

        # Security Headers
        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

        # Proxy to smartstore-app (handles subdomain routing)
        location / {
            proxy_pass http://smartstore_app;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection 'upgrade';
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_cache_bypass $http_upgrade;
            
            # Timeouts
            proxy_connect_timeout 60s;
            proxy_send_timeout 60s;
            proxy_read_timeout 60s;
        }

        # Health check endpoint
        location /health {
            access_log off;
            return 200 "healthy\n";
            add_header Content-Type text/plain;
        }
    }

    # API endpoints (if needed separately)
    server {
        listen 443 ssl http2;
        server_name api.smartstore.org;

        ssl_certificate /etc/ssl/smartstore/base-domain.crt;
        ssl_certificate_key /etc/ssl/smartstore/base-domain.key;

        ssl_protocols TLSv1.2 TLSv1.3;
        ssl_ciphers HIGH:!aNULL:!MD5;
        ssl_prefer_server_ciphers on;

        # Rate limiting for API
        limit_req zone=api_limit burst=20 nodelay;

        location / {
            proxy_pass http://smartstore_api;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }
    }

    # Custom domains (dynamically loaded)
    # Configs are generated by nginx.service.js and placed in:
    # /etc/nginx/sites-enabled/custom-domains/*.conf
    include /etc/nginx/sites-enabled/custom-domains/*.conf;
}

