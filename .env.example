# =============================================================================
# Copy to .env and edit. Never commit .env.
# =============================================================================

# --- App ---
APP_NAME=Your App
NODE_ENV=development
# Default deployment port for this service. docker-compose binds host:${PORT}.
PORT=5269
# Public URL of this API (OAuth callbacks, email links, local file URLs)
API_BASE_URL=http://localhost:5269
FRONTEND_URL=http://localhost:5270
# Optional: used in some auth email links if set (e.g. Next.js public URL)
# NEXT_PUBLIC_APP_URL=http://localhost:5270

# --- Database (required) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=your_app

# --- JWT (required for auth) ---
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_REFRESH_EXPIRES_IN=30d

# --- CORS (required for browser clients) ---
# Comma-separated origins
CORS_ORIGIN=http://localhost:3000

# --- Rate limiting (reserved) ---
# Passed through Docker Compose; not read by application code yet — add middleware if needed.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- Logging ---
# LOG_LEVEL sets Winston verbosity (error, warn, info, debug, …). If unset: debug when
# NODE_ENV=development or LOG_DEBUG=true, otherwise info.
LOG_DEBUG=false
LOG_LEVEL=info
# LOG_FORMAT=json
# LOG_DIR=logs
# LOG_MAX_DAYS=14
# LOG_DATE_PATTERN=YYYY-MM-DD

# --- File storage ---
# mock | local | s3 — see src/modules/files/services/file.service.js
DEFAULT_FILE_PROVIDER=mock

# AWS S3 (when DEFAULT_FILE_PROVIDER=s3 or for signed URLs)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Bucket name (AWS_S3_BUCKET is an accepted alias)
AWS_S3_BUCKET_NAME=
AWS_S3_BUCKET=
AWS_S3_BUCKET_BASE_URL=

# Storage quota (MB per user; -1 for unlimited)
STORAGE_LIMIT_MB=1024

# --- SMTP (optional — required for real password reset / welcome email) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=no-reply@example.com

# --- Redis (optional — not used by current codebase; reserved for queues/cache) ---
REDIS_URL=redis://localhost:6379

# --- OAuth (optional — leave blank to disable a provider) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=

# --- Payments (optional — seed payment_methods in DB; keys stored on rows, not here) ---
# Public stats on GET /payments/stats: progress bar denominator (amount in same currency as totals)
# PAYMENT_STATS_MONTHLY_GOAL=1000000
# Flutterwave hosted checkout logo URL (optional)
# FLW_CHECKOUT_LOGO_URL=https://example.com/logo.png
# Direct-transfer instructions email requires SMTP_* and FROM_EMAIL above.

# --- Posts / comments / SEO / rate limits (optional) ---
# Max nesting depth for replies
# POST_COMMENT_MAX_DEPTH=20
# Honeypot field name — if set and client sends a non-empty value, comment create returns 400 (bots)
# POST_COMMENT_HONEYPOT_FIELD=company_website
# Rate limits (per user_id or IP), window default 60000 ms
# POST_READ_RATE_LIMIT_MAX=120
# POST_WRITE_RATE_LIMIT_MAX=20
# POST_COMMENT_RATE_LIMIT_MAX=25
# POST_LIKE_RATE_LIMIT_MAX=60
# POST_RATE_LIMIT_WINDOW_MS=60000

# --- API docs ---
# If set, /docs requires HTTP Basic auth (password only; username can be anything)
API_DOCS_PASSWORD=

# --- JUPEB (optional) ---
# Hours until a newly generated institution claim code expires. Empty or 0 = no expiry.
# JUPEB_INSTITUTION_CODE_TTL_HOURS=24
# When true, student-facing JUPEB routes (claim, checkout, submissions) allow only student + user roles.
# Default false also allows admin and super_admin for support and tests.
# JUPEB_STUDENT_ROUTES_STRICT=false

# --- Tests only (set by src/tests/setup.js; optional overrides for local test runs) ---
# USE_MOCK_OTP=true
# MOCK_OTP_CODE=123456
# SKIP_EMAIL_VERIFICATION=true
# SKIP_SMS_VERIFICATION=true
